
<!DOCTYPE html>
<html lang='en'>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>The Salt Supply | Integrated Platform</title>
    <script src='https://cdn.tailwindcss.com'></script>
    <script src='https://cdn.jsdelivr.net/npm/chart.js'></script>
    <link href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap' rel='stylesheet'>
    <style>
        :root {
            --primary: #2C5F2D;
            --accent: #E2725B;
            --bg: #F4F5F2;
            --text: #2D3436;
            --white: #ffffff;
            --kindness: #2A9D8F;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding-top: 100px;
        }

        .playfair { font-family: 'Playfair Display', serif; }

        header {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding: 15px 0;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary);
            cursor: pointer;
        }

        .nav-links button {
            margin-left: 20px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text);
            transition: color 0.3s;
        }

        .nav-links button:hover { color: var(--accent); }
        .nav-links .active { color: var(--accent); border-bottom: 2px solid var(--accent); }

        .main-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 30px 60px 30px;
        }

        .glass-card {
            background: var(--white);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 12px 40px rgba(44, 95, 45, 0.08);
            border: 1px solid rgba(255,255,255,0.5);
        }

        .need-card {
            background: var(--white);
            border-radius: 16px;
            padding: 25px;
            margin-bottom: 20px;
            border-left: 6px solid var(--primary);
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            transition: transform 0.2s;
        }

        .kindness-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
        }

        .kindness-card:hover {
            border-color: var(--kindness);
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(42, 157, 143, 0.1);
        }

        .cta-button {
            background: var(--primary);
            color: var(--white);
            font-weight: 700;
            padding: 12px 24px;
            border-radius: 10px;
            text-transform: uppercase;
            font-size: 0.8rem;
            transition: all 0.3s;
        }

        .cta-button:hover { background: var(--text); transform: translateY(-2px); }

        .points-badge {
            background: #E9F5F3;
            color: var(--kindness);
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 800;
            font-size: 0.7rem;
        }

        footer {
            background: #fff;
            padding: 40px 0;
            text-align: center;
            border-top: 1px solid #eee;
            font-size: 0.8rem;
            color: #888;
        }
    </style>
</head>
<body>

<header>
    <div class='nav-container'>
        <div class='logo' onclick="showView('home')">the salt supply.</div>
        <div class='nav-links'>
            <button id='nav-home' onclick="showView('home')">Vision</button>
            <button id='nav-exchange' onclick="showView('exchange')">The Exchange</button>
            <button id='nav-social' onclick="showView('social')">Kindness Circle</button>
            <button id='nav-staff' onclick="showView('staff')">Join Staff</button>
            <button id='nav-partner' onclick="showView('partner')">Partner</button>
        </div>
    </div>
</header>

<div class='main-wrapper' id='content-root'></div>

<footer>
    &copy; 2026 The Salt Supply Project. <br>
    <i class='playfair'>"Whatever you did for one of the least of these, you did for me."</i>
</footer>

<script>
    function showView(view) {
        const root = document.getElementById('content-root');
        root.style.opacity = 0;

        // Update Nav UI
        document.querySelectorAll('.nav-links button').forEach(btn => btn.classList.remove('active'));
        document.getElementById('nav-' + view).classList.add('active');

        setTimeout(() => {
            if (view === 'home') {
                root.innerHTML = `
                    <div class='py-16 text-center animate-fade'>
                        <span class='font-extrabold text-xs uppercase tracking-[0.3em] text-[#E2725B]'>Pilot Project 2026</span>
                        <h1 class='playfair text-6xl font-bold mt-6 mb-8 text-[#2C5F2D]'>Mission-Critical <br><i>Mercy.</i></h1>
                        <p class='max-w-2xl mx-auto text-lg text-gray-600 mb-10'>We bridge the gap between messy human needs and rigorous professional data. From engine swaps to a simple cup of coffee, we document the power of redemptive kindness.</p>
                        <div class='flex justify-center gap-4'>
                            <button class='cta-button' onclick="showView('exchange')">View The Exchange</button>
                            <button class='cta-button bg-[#2A9D8F] hover:bg-[#1A3628]' onclick="showView('social')">Enter Kindness Circle</button>
                        </div>
                    </div>
                `;
            } else if (view === 'exchange') {
                root.innerHTML = `
                    <div class='py-10 grid grid-cols-1 lg:grid-cols-3 gap-10'>
                        <div class='lg:col-span-2'>
                            <h2 class='playfair text-3xl font-bold mb-8'>Active Need Feed</h2>
                            <div class='need-card border-l-[#E2725B]'>
                                <span class='tag' style='background: #FFEBEB; color: #D9534F;'>Void-Level • Mechanical</span>
                                <h3 class='font-bold text-xl mb-2'>Seized Engine Replacement</h3>
                                <p class='text-gray-600 mb-4'>Single mother requires engine swap to maintain employment. Parts secured, professional labor required.</p>
                                <button class='font-bold text-xs uppercase text-[#E2725B] tracking-widest'>I Can Serve &rarr;</button>
                            </div>
                        </div>
                        <div class='space-y-6'>
                            <div class='glass-card'>
                                <h3 class='playfair font-bold text-lg mb-2 text-center'>Crisis Matrix Logic</h3>
                                <canvas id='matrixChart'></canvas>
                            </div>
                        </div>
                    </div>
                `;
                renderMatrix();
            } else if (view === 'social') {
                root.innerHTML = `
                    <div class='py-10'>
                        <div class='flex justify-between items-end mb-10'>
                            <div>
                                <h2 class='playfair text-4xl font-bold text-[#2A9D8F]'>Kindness Circle</h2>
                                <p class='text-gray-500 mt-2'>No act is too small to be redemptive. Ask for a coffee, a chat, or a hand.</p>
                            </div>
                            <button class='cta-button bg-[#2A9D8F]'>Post a Little Wish</button>
                        </div>

                        <div class='grid grid-cols-1 md:grid-cols-3 gap-6'>
                            <div class='kindness-card'>
                                <div class='flex justify-between items-start mb-4'>
                                    <span class='points-badge'>+10 Legacy Pts</span>
                                    <span class='text-[10px] text-gray-400'>2 mins ago</span>
                                </div>
                                <h4 class='font-bold'>Study Partner Needed</h4>
                                <p class='text-sm text-gray-600 my-3'>"Struggling with mid-term calculus. Anyone free for an hour at the library to walk through derivatives?"</p>
                                <div class='flex items-center gap-2 mt-4'>
                                    <div class='w-6 h-6 bg-gray-200 rounded-full'></div>
                                    <span class='text-xs font-bold'>Sarah M.</span>
                                </div>
                                <button class='w-full mt-4 py-2 text-xs font-black uppercase text-[#2A9D8F] border border-[#2A9D8F] rounded-lg hover:bg-[#2A9D8F] hover:text-white transition-all'>I'll Help Sarah</button>
                            </div>

                            <div class='kindness-card'>
                                <div class='flex justify-between items-start mb-4'>
                                    <span class='points-badge'>+5 Legacy Pts</span>
                                    <span class='text-[10px] text-gray-400'>15 mins ago</span>
                                </div>
                                <h4 class='font-bold'>Coffee & Conversation</h4>
                                <p class='text-sm text-gray-600 my-3'>"Just moved here and don't know anyone yet. Would love to grab a coffee and hear about the best spots in town."</p>
                                <div class='flex items-center gap-2 mt-4'>
                                    <div class='w-6 h-6 bg-gray-200 rounded-full'></div>
                                    <span class='text-xs font-bold'>James L.</span>
                                </div>
                                <button class='w-full mt-4 py-2 text-xs font-black uppercase text-[#2A9D8F] border border-[#2A9D8F] rounded-lg hover:bg-[#2A9D8F] hover:text-white transition-all'>Meet James</button>
                            </div>

                            <div class='glass-card bg-[#1A3628] text-white flex flex-col justify-center items-center text-center'>
                                <h4 class='playfair text-xl font-bold mb-2'>Why Little Acts?</h4>
                                <p class='text-xs opacity-80 mb-4'>Professional skills solve crises, but small acts build the trust infrastructure that prevents them.</p>
                                <div class='text-2xl font-bold text-[#E2725B]'>1,240</div>
                                <div class='text-[10px] uppercase tracking-widest opacity-60'>Smiles Documented Today</div>
                            </div>
                        </div>
                    </div>
                `;
            } else if (view === 'staff') {
                root.innerHTML = `
                    <div class='py-10 grid grid-cols-1 md:grid-cols-2 gap-16'>
                        <div>
                            <h2 class='playfair text-4xl font-bold mb-6 text-[#2C5F2D]'>The Character Funnel</h2>
                            <p class='text-gray-600 mb-10'>Your Level 10 skills are needed. Every small act in the Kindness Circle feeds into your Salt Staff application score.</p>
                            <div class='funnel-layer bg-[#264653] w-full'>Applicants Onboarded</div>
                            <div class='funnel-layer bg-[#2A9D8F] w-4/5'>Legacy Points Review</div>
                            <div class='funnel-layer bg-[#E2725B] w-3/5'>Vow of Silence</div>
                            <div class='funnel-layer bg-[#2C5F2D] w-2/5 font-bold'>Salt Staff</div>
                        </div>
                        <div class='glass-card'>
                            <h3 class='playfair text-2xl font-bold mb-6'>Join the Vow</h3>
                            <input type='text' placeholder='Full Name'>
                            <textarea rows='4' placeholder='How have your small acts of kindness prepared you for big acts of mercy?'></textarea>
                            <button class='cta-button w-full'>Submit Application</button>
                        </div>
                    </div>
                `;
            } else if (view === 'partner') {
                root.innerHTML = `
                    <div class='py-10 text-center'>
                        <h2 class='playfair text-4xl font-bold mb-4'>Impact-as-a-Service</h2>
                        <p class='text-gray-500 mb-16'>Corporate sponsorship with verified Character ROI from both big and small acts.</p>
                        <div class='grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto'>
                            <div class='glass-card border-t-8 border-[#2C5F2D]'>
                                <div class='playfair text-2xl font-bold mb-4'>THE ANCHOR</div>
                                <div class='text-4xl font-bold text-[#2C5F2D] mb-6'>$50k<span class='text-sm text-gray-400'>/yr</span></div>
                                <button class='cta-button w-full'>Request SLA</button>
                            </div>
                            <div class='glass-card'>
                                <div class='playfair text-2xl font-bold mb-4'>PARTNER</div>
                                <div class='text-4xl font-bold text-[#2C5F2D] mb-6'>$10k<span class='text-sm text-gray-400'>/yr</span></div>
                                <button class='cta-button w-full bg-[#F0F2F0] !text-gray-600'>Inquire</button>
                            </div>
                        </div>
                    </div>
                `;
            }
            root.style.opacity = 1;
        }, 50);
    }

    function renderMatrix() {
        const ctx = document.getElementById('matrixChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Safety', 'Livelihood', 'Dependent', 'Skill'],
                datasets: [{
                    data: [35, 30, 20, 15],
                    backgroundColor: ['#E2725B', '#2A9D8F', '#E9C46A', '#264653'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } }
            }
        });
    }

    document.addEventListener('DOMContentLoaded', () => showView('home'));
</script>

</body>
</html>
